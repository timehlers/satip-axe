diff --git a/src/compat/charconv b/src/compat/charconv
new file mode 100644
index 0000000..6d5c791
--- /dev/null
+++ b/src/compat/charconv
@@ -0,0 +1,29 @@
+#pragma once
+
+#include <cerrno>
+#include <cstdlib>
+#include <system_error>
+
+namespace std {
+
+struct from_chars_result {
+    const char *ptr;
+    errc ec;
+};
+
+inline from_chars_result from_chars(const char *first, const char *last,
+                                    int &value) {
+    char *end = NULL;
+    errno = 0;
+    long parsed = strtol(first, &end, 10);
+    if (end == first)
+        return {first, errc::invalid_argument};
+    if (errno == ERANGE)
+        return {end, errc::result_out_of_range};
+    if (end > last)
+        return {last, errc::invalid_argument};
+    value = static_cast<int>(parsed);
+    return {end, errc{}};
+}
+
+} // namespace std
diff --git a/src/compat/optional b/src/compat/optional
new file mode 100644
index 0000000..5c6804a
--- /dev/null
+++ b/src/compat/optional
@@ -0,0 +1,165 @@
+#pragma once
+
+#include <stdexcept>
+#include <utility>
+
+namespace std {
+
+struct nullopt_t {
+    explicit nullopt_t(int) {}
+};
+
+static const nullopt_t nullopt(0);
+
+template <typename T> class optional {
+  public:
+    optional() : engaged_(false), value_() {}
+    optional(nullopt_t) : engaged_(false), value_() {}
+    optional(const T &value) : engaged_(true), value_(value) {}
+    optional(T &&value) : engaged_(true), value_(std::move(value)) {}
+
+    optional &operator=(nullopt_t) {
+        engaged_ = false;
+        value_ = T();
+        return *this;
+    }
+
+    optional &operator=(const T &value) {
+        engaged_ = true;
+        value_ = value;
+        return *this;
+    }
+
+    optional &operator=(T &&value) {
+        engaged_ = true;
+        value_ = std::move(value);
+        return *this;
+    }
+
+    bool has_value() const { return engaged_; }
+    explicit operator bool() const { return engaged_; }
+
+    T &value() {
+        if (!engaged_)
+            throw std::runtime_error("bad optional access");
+        return value_;
+    }
+
+    const T &value() const {
+        if (!engaged_)
+            throw std::runtime_error("bad optional access");
+        return value_;
+    }
+
+    template <typename U> T value_or(U default_value) const {
+        return engaged_ ? value_ : static_cast<T>(default_value);
+    }
+
+    void reset() {
+        engaged_ = false;
+        value_ = T();
+    }
+
+    T &operator*() { return value(); }
+    const T &operator*() const { return value(); }
+    T *operator->() { return &value(); }
+    const T *operator->() const { return &value(); }
+
+  private:
+    bool engaged_;
+    T value_;
+};
+
+template <typename T> optional<T> make_optional(T value) {
+    return optional<T>(std::move(value));
+}
+
+template <typename T> bool operator==(const optional<T> &o, nullopt_t) {
+    return !o.has_value();
+}
+
+template <typename T> bool operator==(nullopt_t, const optional<T> &o) {
+    return !o.has_value();
+}
+
+template <typename T> bool operator!=(const optional<T> &o, nullopt_t) {
+    return o.has_value();
+}
+
+template <typename T> bool operator!=(nullopt_t, const optional<T> &o) {
+    return o.has_value();
+}
+
+template <typename T>
+bool operator==(const optional<T> &a, const optional<T> &b) {
+    if (a.has_value() != b.has_value())
+        return false;
+    return !a.has_value() || *a == *b;
+}
+
+template <typename T>
+bool operator!=(const optional<T> &a, const optional<T> &b) {
+    return !(a == b);
+}
+
+template <typename T, typename U>
+bool operator==(const optional<T> &a, const U &b) {
+    return a.has_value() && *a == b;
+}
+
+template <typename T, typename U>
+bool operator==(const U &a, const optional<T> &b) {
+    return b == a;
+}
+
+template <typename T, typename U>
+bool operator!=(const optional<T> &a, const U &b) {
+    return !(a == b);
+}
+
+template <typename T, typename U>
+bool operator!=(const U &a, const optional<T> &b) {
+    return !(a == b);
+}
+
+template <typename T, typename U>
+bool operator<=(const optional<T> &a, const U &b) {
+    return a.has_value() && *a <= b;
+}
+
+template <typename T, typename U>
+bool operator<=(const U &a, const optional<T> &b) {
+    return b.has_value() && a <= *b;
+}
+
+template <typename T, typename U>
+bool operator<(const optional<T> &a, const U &b) {
+    return a.has_value() && *a < b;
+}
+
+template <typename T, typename U>
+bool operator<(const U &a, const optional<T> &b) {
+    return b.has_value() && a < *b;
+}
+
+template <typename T, typename U>
+bool operator>=(const optional<T> &a, const U &b) {
+    return a.has_value() && *a >= b;
+}
+
+template <typename T, typename U>
+bool operator>=(const U &a, const optional<T> &b) {
+    return b.has_value() && a >= *b;
+}
+
+template <typename T, typename U>
+bool operator>(const optional<T> &a, const U &b) {
+    return a.has_value() && *a > b;
+}
+
+template <typename T, typename U>
+bool operator>(const U &a, const optional<T> &b) {
+    return b.has_value() && a > *b;
+}
+
+} // namespace std
diff --git a/src/compat/ranges b/src/compat/ranges
new file mode 100644
index 0000000..e490834
--- /dev/null
+++ b/src/compat/ranges
@@ -0,0 +1,20 @@
+#pragma once
+
+#include <algorithm>
+
+namespace std {
+namespace ranges {
+
+template <typename R1, typename R2, typename Pred>
+bool equal(const R1 &a, const R2 &b, Pred pred) {
+    typename R1::const_iterator ia = a.begin();
+    typename R2::const_iterator ib = b.begin();
+    for (; ia != a.end() && ib != b.end(); ++ia, ++ib) {
+        if (!pred(*ia, *ib))
+            return false;
+    }
+    return ia == a.end() && ib == b.end();
+}
+
+} // namespace ranges
+} // namespace std
diff --git a/src/compat/string_view b/src/compat/string_view
new file mode 100644
index 0000000..d57937c
--- /dev/null
+++ b/src/compat/string_view
@@ -0,0 +1,127 @@
+#pragma once
+
+#include <cstring>
+#include <string>
+
+namespace std {
+
+class string_view {
+  public:
+    typedef const char *const_iterator;
+    static const size_t npos = static_cast<size_t>(-1);
+
+    string_view() : data_(""), size_(0) {}
+    string_view(const char *s) : data_(s ? s : ""), size_(s ? strlen(s) : 0) {}
+    string_view(const char *s, size_t count) : data_(s ? s : ""), size_(count) {}
+    string_view(const std::string &s) : data_(s.data()), size_(s.size()) {}
+
+    const char *data() const { return data_; }
+    size_t size() const { return size_; }
+    bool empty() const { return size_ == 0; }
+
+    const char &operator[](size_t pos) const { return data_[pos]; }
+    const char &back() const { return data_[size_ - 1]; }
+
+    const_iterator begin() const { return data_; }
+    const_iterator end() const { return data_ + size_; }
+
+    void remove_prefix(size_t n) {
+        if (n > size_)
+            n = size_;
+        data_ += n;
+        size_ -= n;
+    }
+
+    string_view substr(size_t pos, size_t count = npos) const {
+        if (pos > size_)
+            pos = size_;
+        size_t remaining = size_ - pos;
+        if (count == npos || count > remaining)
+            count = remaining;
+        return string_view(data_ + pos, count);
+    }
+
+    size_t find(char c, size_t pos = 0) const {
+        for (size_t i = pos; i < size_; ++i)
+            if (data_[i] == c)
+                return i;
+        return npos;
+    }
+
+    size_t find(string_view needle, size_t pos = 0) const {
+        if (needle.size_ == 0)
+            return pos <= size_ ? pos : npos;
+        if (needle.size_ > size_)
+            return npos;
+        for (size_t i = pos; i + needle.size_ <= size_; ++i)
+            if (memcmp(data_ + i, needle.data_, needle.size_) == 0)
+                return i;
+        return npos;
+    }
+
+    size_t find(const char *needle, size_t pos = 0) const {
+        return find(string_view(needle), pos);
+    }
+
+    bool contains(string_view needle) const { return find(needle) != npos; }
+    bool contains(const char *needle) const { return contains(string_view(needle)); }
+    bool contains(char needle) const { return find(needle) != npos; }
+
+    bool starts_with(string_view prefix) const {
+        return size_ >= prefix.size_ &&
+               memcmp(data_, prefix.data_, prefix.size_) == 0;
+    }
+
+    bool starts_with(const char *prefix) const {
+        return starts_with(string_view(prefix));
+    }
+
+    bool ends_with(string_view suffix) const {
+        return size_ >= suffix.size_ &&
+               memcmp(data_ + size_ - suffix.size_, suffix.data_, suffix.size_) ==
+                   0;
+    }
+
+    bool ends_with(const char *suffix) const {
+        return ends_with(string_view(suffix));
+    }
+
+    bool ends_with(char suffix) const {
+        return size_ > 0 && data_[size_ - 1] == suffix;
+    }
+
+    size_t find_first_not_of(const char *chars, size_t pos = 0) const {
+        for (size_t i = pos; i < size_; ++i) {
+            if (strchr(chars, data_[i]) == NULL)
+                return i;
+        }
+        return npos;
+    }
+
+    std::string str() const { return std::string(data_, size_); }
+    operator std::string() const { return str(); }
+
+  private:
+    const char *data_;
+    size_t size_;
+};
+
+inline bool operator==(string_view a, string_view b) {
+    return a.size() == b.size() && memcmp(a.data(), b.data(), a.size()) == 0;
+}
+
+inline bool operator!=(string_view a, string_view b) { return !(a == b); }
+
+inline bool operator==(string_view a, const char *b) {
+    return a == string_view(b);
+}
+
+inline bool operator!=(string_view a, const char *b) { return !(a == b); }
+
+inline bool operator==(const char *a, string_view b) {
+    return string_view(a) == b;
+}
+
+inline bool operator!=(const char *a, string_view b) { return !(a == b); }
+
+} // namespace std
