FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        cmake \
        g++ \
        gcc \
        git \
        make \
        patch \
        pkg-config \
        xz-utils && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /build

ENTRYPOINT ["make"]
